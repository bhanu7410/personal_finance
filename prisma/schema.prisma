// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int           @id @default(autoincrement())
  
  // The ID from Stack Auth (String). Make it unique so we can look users up by it.
  externalId   String        @unique  
  
  email        String        @unique
  name         String?
  upi_id         String?       @unique
  
  // Remove the password field! You don't need it.
  // password  String  

  createdAt    DateTime      @default(now())
  
  // Relations remain the same
  transactions Transaction[] 
  groups       UserGroup[]   
  splits       Split[]       
}

model Group {
  id           Int           @id @default(autoincrement())
  name         String
  createdAt    DateTime      @default(now())
  
  // Relations
  members      UserGroup[]
  transactions Transaction[]
}

// Explicit Many-to-Many table. 
// This allows you to add extra fields like "joinedAt" or "role" (Admin/Member) later.
model UserGroup {
  id        Int      @id @default(autoincrement())
  userId    Int
  groupId   Int
  joinedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  group     Group    @relation(fields: [groupId], references: [id])

  @@unique([userId, groupId]) // A user can't join the same group twice
}

model Transaction {
  id          Int      @id @default(autoincrement())
  amount      Decimal  @db.Decimal(12, 2)
  description String
  date        DateTime @default(now())
  category    String   // Consider making this an Enum later
  
  // Who PAID for this?
  payerId     Int
  payer       User     @relation(fields: [payerId], references: [id])

  // Is this linked to a group? (Optional)
  groupId     Int?     
  group       Group?   @relation(fields: [groupId], references: [id])

  // How is the cost divided?
  splits      Split[]
}

// This is the magic table for Group Finance (The "Splitwise" logic)
model Split {
  id            Int         @id @default(autoincrement())
  amount        Decimal     @db.Decimal(12, 2) // How much THIS user owes
  
  userId        Int
  user          User        @relation(fields: [userId], references: [id])
  
  transactionId Int
  transaction   Transaction @relation(fields: [transactionId], references: [id])
}